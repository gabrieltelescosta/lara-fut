DATABASE_URL="file:./dev.db"
# Bearer para GET /api/cron/collector e POST /api/strategy-sim/refresh (Vercel Cron ou curl)
CRON_SECRET="change-me"
# true = coletor + sinais automáticos + tracker a cada 1 min (next dev / next start em máquina fixa)
# Na Vercel use false e deixe só o Cron em vercel.json chamando /api/cron/collector
ENABLE_COLLECTOR_CRON="true"

# false = só captura: eventos, odds, resultados, liquidação — sem criar/resolver sinais nem sim estratégia
# Quando tiveres histórico, muda para true (ou apaga a linha; omissão = sinais ligados)
# ENABLE_SIGNALS="false"
# ENABLE_SIGNALS="true"

# true = grava novo lote de odds em cada coleta mesmo sem mudança de cotações (mais dados, SQLite cresce rápido).
# ODDS_SKIP_HASH_DEDUPE="true"

# Mercados gravados no sinal automático (coletor), separados por vírgula.
# Sugestão (4 mercados): 1X2, Dupla, BTTS, gols mandante ±2.5
# omissão = oneX2,btts,teamOu
# Ids válidos: oneX2, btts, teamOu, totalGolsJogo, duplaChance, faixaGolsTotais,
# resultadoFinalTotalGols, numeroExatoGols, timeNumeroExatoGols, placarCorreto, resultadoFinalAmbasMarcam
SIGNAL_MARKETS_ENABLED="oneX2,duplaChance,btts,teamOu"

# true = escolhe o jogo cujo mandante tem maior % walk-forward (SIGNAL_RANK_MARKET, default teamOu).
# Enquanto existir um sinal pendente (sem resultado), não cria outro — evita vários Telegrams no mesmo período.
# SIGNAL_MIN_EVALUATED_GAMES = mínimo de jogos como mandante com pick nesse mercado (default 3)
SIGNAL_BEST_HOME_TEAM_ONLY="false"
# SIGNAL_RANK_MARKET="teamOu"
# Para operar só TeamOu com melhor mandante + gales:
# SIGNAL_MARKETS_ENABLED="teamOu"
# SIGNAL_BEST_HOME_TEAM_ONLY="true"
# SIGNAL_RANK_MARKET="teamOu"

# Folga mínima (min) entre agora e o início do jogo — ex.: 5 → às 17:50 o sinal aponta para ≥17:55 (tempo p/ apostar).
# SIGNAL_MIN_LEAD_MINUTES="5"
# Até quantos minutos à frente buscar jogos (lista > folga; default 15).
# SIGNAL_LOOKAHEAD_MINUTES="15"

# Telegram (opcional): envia texto quando cria sinal e quando resolve
# Preferência: definir em /settings/telegram (guardado na BD). Estas variáveis são fallback
# quando o campo correspondente na BD está vazio.
# Criar bot em https://t.me/BotFather — obter chat_id (ex. enviar msg ao bot e GET getUpdates)
TELEGRAM_ENABLED="false"
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
# Com SIGNAL_BEST_HOME_TEAM_ONLY: vazio = só 1 mercado (= SIGNAL_RANK_MARKET, default teamOu).
# Se definir lista, só o primeiro id conta.
# Sem essa flag: vazio = igual a SIGNAL_MARKETS_ENABLED
# TELEGRAM_SIGNAL_MARKETS="teamOu"
# Gales após RED (recuperações). Total de jogadas = 1 + TELEGRAM_GALE_MAX (ex.: 3 → 4 jogos).
# TELEGRAM_GALE_MAX="3"
# Fuso nos horários do Telegram (default America/Sao_Paulo)
# TELEGRAM_TIMEZONE="America/Sao_Paulo"
